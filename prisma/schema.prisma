// ─── Sprint 23: Worker Daemon ────────────────────────────────────
// Safety: WorkerInstance, TaskQueueJob, and WorkerHeartbeat are local execution
// infrastructure records. They enable asynchronous task processing but do not
// grant runtime permissions, route tasks, or complete tasks autonomously.
// All worker actions are audited and subject to existing governance boundaries.

model WorkerInstance {
  id                String   @id
  workerId          String   @unique
  status            String   @default("offline")   // online | offline | draining
  capabilitiesJson  String   @default("[]")        // ["sandbox", "git", "api", "deploy"]
  maxConcurrent     Int      @default(1)
  currentJobId      String?
  lastHeartbeatAt   DateTime @default(now())
  startedAt         DateTime @default(now())
  stoppedAt         DateTime?

  @@index([status])
  @@index([lastHeartbeatAt])
  @@map("worker_instances")
}

model TaskQueueJob {
  id                       String   @id @default(cuid())
  idempotencyKey           String?  @unique
  taskId                   String
  correlationId            String
  priority                 Int      @default(2)       // 0=紧急, 1=高, 2=普通, 3=低
  status                   String   @default("pending") // pending | assigned | running | completed | failed | dead_letter
  requiredCapabilitiesJson String   @default("[]")    // ["sandbox", "git"]
  requiredAgentRolesJson   String   @default("[]")    // ["engineering", "verification"]
  maxRetries               Int      @default(3)
  retryCount               Int      @default(0)
  timeoutMs                Int      @default(60000)
  scheduledAt              DateTime @default(now())
  assignedWorkerId         String?
  leaseExpiresAt           DateTime?
  lastErrorJson            String?
  attemptCount             Int      @default(0)
  startedAt                DateTime?
  completedAt              DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([status, priority])
  @@index([assignedWorkerId])
  @@index([taskId])
  @@index([scheduledAt])
  @@index([idempotencyKey])
  @@index([correlationId])
  @@index([createdAt])
  @@map("task_queue_jobs")
}

model WorkerHeartbeat {
  id          String   @id @default(cuid())
  workerId    String
  jobId       String?
  status      String   @default("idle")  // idle | busy | draining
  metricsJson String   @default("{}")    // {"activeJobs":0,"completedToday":5,"avgDurationMs":12000}
  createdAt   DateTime @default(now())

  @@index([workerId])
  @@index([createdAt])
  @@map("worker_heartbeats")
}

// 概念治理 / 规则中枢
model ConceptGlossary {
  id                     String   @id @default(cuid())
  idempotencyKey         String?  @unique
  conceptType            String   // term, risk_classification, execution_boundary, lifecycle_phase, review_criteria, policy
  name                   String
  displayName            String
  description            String
  definition             String   @default("{}")  // JSON object with detailed definition
  applicableToJson       String   @default("[]")  // JSON array of applicable contexts
  relatedConceptsJson    String   @default("[]")  // JSON array of related concept IDs
  examplesJson           String   @default("[]")  // JSON array of examples
  status                 String   @default("active")  // active, deprecated, draft
  version                Int      @default(1)
  createdBy              String
  reviewedBy             String?
  reviewedAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([conceptType])
  @@index([name])
  @@index([status])
  @@index([createdAt])
  @@map("concept_glossary")
}


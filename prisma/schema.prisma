generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id           String   @id @default(cuid())
  title        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages     Message[]
  tasks        HarmonyTask[]
  deliverables Deliverable[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  status         String       @default("complete")
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// ─── Sprint 16: Agent 交付物 ─────────────────────────────
model Deliverable {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentId        String
  agentName      String
  taskTitle      String
  type           String   // document | code | analysis | report | plan
  title          String
  content        String
  format         String   // markdown | json | code
  summary        String
  confidence     Float
  metadataJson   String   @default("{}")
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([agentId])
  @@index([type])
  @@index([createdAt])
  @@map("deliverables")
}

model HarmonyTask {
  id                        String   @id @default(cuid())
  idempotencyKey            String?  @unique
  conversationId            String?
  conversation              Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  sourceMessageId           String?
  sourceMessageText         String
  title                     String
  description               String
  type                      String
  status                    String
  routeDecisionType         String
  routeStatus               String
  targetAgentId             String?
  confidence                Float
  reason                    String
  statusReason              String?
  matchedSignalsJson        String
  routeDecisionSnapshotJson String
  requiresHumanConfirmation Boolean
  sideEffectsJson           String
  createdBy                 String
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  runs          HarmonyTaskRun[]
  steps         HarmonyTaskStep[]
  auditEvents   HarmonyAuditEvent[]
  confirmations HarmonyConfirmationArtifact[]
  agentRuns     AgentRun[]
  agentSteps    AgentStep[]
  memoryEntries MemoryEntry[]
  contextPackets ContextPacket[]
  a2aMessages   A2AMessage[]
  toolCalls     ToolCall[]
  toolRuns      ToolRun[]
  fileChangeProposals FileChangeProposal[]
  externalActionProposals ExternalActionProposal[]

  @@index([conversationId])
  @@index([status])
  @@index([targetAgentId])
  @@index([createdAt])
  @@map("harmony_tasks")
}

model HarmonyTaskRun {
  id          String   @id @default(cuid())
  taskId      String
  task        HarmonyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status      String
  trigger     String
  attempt     Int
  runtimeKind String
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       HarmonyTaskStep[]
  auditEvents HarmonyAuditEvent[]
  agentRuns   AgentRun[]

  @@index([taskId])
  @@index([status])
  @@map("harmony_task_runs")
}

model HarmonyTaskStep {
  id                    String   @id @default(cuid())
  taskId                String
  task                  HarmonyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskRunId             String
  taskRun               HarmonyTaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  index                 Int
  kind                  String
  status                String
  agentId               String?
  summary               String
  inputJson             String
  outputJson            String?
  confidence            Float?
  nextRecommendedAction String?
  sideEffectsJson       String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  auditEvents HarmonyAuditEvent[]
  agentRun    AgentRun?

  @@index([taskId])
  @@index([taskRunId])
  @@index([status])
  @@map("harmony_task_steps")
}

model HarmonyAuditEvent {
  id            String   @id @default(cuid())
  correlationId String?
  taskId        String?
  task          HarmonyTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskRunId     String?
  taskRun       HarmonyTaskRun? @relation(fields: [taskRunId], references: [id], onDelete: SetNull)
  taskStepId    String?
  taskStep      HarmonyTaskStep? @relation(fields: [taskStepId], references: [id], onDelete: SetNull)
  eventType     String
  actorType     String
  actorId       String?
  beforeStatus  String?
  afterStatus   String?
  reason        String
  payloadJson   String?
  createdAt     DateTime @default(now())

  @@index([correlationId])
  @@index([taskId])
  @@index([eventType])
  @@index([createdAt])
  @@map("harmony_audit_events")
}

model HarmonyConfirmationArtifact {
  id                           String   @id @default(cuid())
  taskId                       String
  task                         HarmonyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status                       String
  action                       String
  reason                       String
  requiresHumanOwner           Boolean
  mustReviewJson               String
  forbiddenRuntimeActionsJson  String
  approvedBy                   String?
  approvedAt                   DateTime?
  decisionReason               String?
  expiresAt                    DateTime?
  payloadJson                  String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([taskId])
  @@index([status])
  @@map("harmony_confirmation_artifacts")
}

model AgentRun {
  id                String   @id @default(cuid())
  correlationId     String?
  taskId            String
  task              HarmonyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskRunId         String?
  taskRun           HarmonyTaskRun? @relation(fields: [taskRunId], references: [id], onDelete: SetNull)
  taskStepId        String? @unique
  taskStep          HarmonyTaskStep? @relation(fields: [taskStepId], references: [id], onDelete: SetNull)
  contextPacketId   String?
  agentId           String
  status            String
  trigger           String
  runtimeMode       String
  attempt           Int
  idempotencyKey    String? @unique
  inputSnapshotJson String
  resultJson        String?
  errorJson         String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  steps AgentStep[]
  contextPackets ContextPacket[]
  memoryEntries MemoryEntry[]
  a2aMessages A2AMessage[]
  toolCalls ToolCall[]
  toolRuns  ToolRun[]

  @@index([correlationId])
  @@index([taskId])
  @@index([status])
  @@index([agentId])
  @@index([createdAt])
  @@map("agent_runs")
}

model AgentStep {
  id          String   @id @default(cuid())
  agentRunId  String
  agentRun    AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  taskId      String
  task        HarmonyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentId     String
  index       Int
  kind        String
  status      String
  summary     String
  inputJson   String?
  outputJson  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentRunId])
  @@index([taskId])
  @@index([status])
  @@map("agent_steps")
}

model MemoryEntry {
  id                         String   @id @default(cuid())
  idempotencyKey             String?  @unique
  status                     String
  title                      String
  content                    String
  kind                       String
  scope                      String
  projectId                  String?
  taskId                     String?
  task                       HarmonyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agentRunId                 String?
  agentRun                   AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  agentId                    String?
  sourceType                 String
  sourceId                   String?
  sourceSnapshotJson         String?
  confidence                 Float
  tagsJson                   String
  supersedesMemoryEntryId    String?
  supersededByMemoryEntryId  String?
  proposedBy                 String
  reviewedBy                 String?
  reviewedAt                 DateTime?
  rejectionReason            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([status])
  @@index([taskId])
  @@index([agentRunId])
  @@index([agentId])
  @@index([createdAt])
  @@map("memory_entries")
}

model KnowledgeItem {
  id                            String   @id @default(cuid())
  idempotencyKey                String?  @unique
  status                        String
  title                         String
  content                       String
  kind                          String
  scope                         String
  projectId                     String?
  sprint                        String?
  agentId                       String?
  sourceType                    String
  sourcePath                    String?
  sourceId                      String?
  sourceSnapshotJson            String?
  tagsJson                      String
  version                       Int
  supersedesKnowledgeItemId     String?
  supersededByKnowledgeItemId   String?
  createdBy                     String
  reviewedBy                    String?
  reviewedAt                    DateTime?
  rejectionReason               String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([sprint])
  @@index([agentId])
  @@index([createdAt])
  @@map("knowledge_items")
}

model ContextPacket {
  id                          String   @id @default(cuid())
  idempotencyKey              String?  @unique
  taskId                      String
  task                        HarmonyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentRunId                  String?
  agentRun                    AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  agentId                     String
  status                      String
  purpose                     String
  selectionPolicyJson         String
  itemsJson                   String
  excludedItemsJson           String?
  approxTokens                Int
  attachedAt                  DateTime?
  attachedToAgentRunId        String?
  supersedesContextPacketId   String?
  supersededByContextPacketId String?
  createdBy                   String
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([taskId])
  @@index([agentRunId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("context_packets")
}

model A2AMessage {
  id                         String   @id @default(cuid())
  idempotencyKey             String?  @unique
  status                     String
  taskId                     String?
  task                       HarmonyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agentRunId                 String?
  agentRun                   AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  fromAgentId                String
  toAgentId                  String
  intent                     String
  subject                    String
  body                       String
  payloadJson                String?
  requiresHumanConfirmation  Boolean
  reviewedBy                 String?
  reviewedAt                 DateTime?
  rejectionReason            String?
  createdBy                  String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([status])
  @@index([taskId])
  @@index([agentRunId])
  @@index([fromAgentId])
  @@index([toAgentId])
  @@index([createdAt])
  @@map("a2a_messages")
}

model ToolCall {
  id                       String   @id @default(cuid())
  idempotencyKey           String?  @unique
  correlationId            String?
  taskId                   String?
  task                     HarmonyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agentRunId               String?
  agentRun                 AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  agentResultId            String?
  source                   String
  toolId                   String
  toolName                 String
  proposedByAgentId        String?
  intent                   String
  rationale                String
  inputJson                String
  inputSummary             String
  status                   String
  riskLevel                String
  sideEffectsJson          String
  permissionDecisionId     String?
  confirmationArtifactId   String?
  sourceSnapshotJson       String?
  policyInputSnapshotJson  String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  permissions ToolPermission[]
  runs        ToolRun[]

  @@index([taskId])
  @@index([agentRunId])
  @@index([toolId])
  @@index([status])
  @@index([createdAt])
  @@map("tool_calls")
}

model ToolPermission {
  id                      String   @id @default(cuid())
  toolCallId              String
  toolCall                ToolCall @relation(fields: [toolCallId], references: [id], onDelete: Cascade)
  toolId                  String
  decision                String
  reason                  String
  evaluatedBy             String
  policyRef               String
  permissionProfileRef    String
  riskLevel               String
  inputValidationStatus   String
  schemaValidationErrorsJson String
  matchedRulesJson        String
  deniedRulesJson         String
  createdAt               DateTime @default(now())

  @@index([toolCallId])
  @@index([toolId])
  @@index([decision])
  @@index([createdAt])
  @@map("tool_permissions")
}

model ToolRun {
  id                String   @id @default(cuid())
  idempotencyKey    String?
  toolCallId        String
  toolCall          ToolCall @relation(fields: [toolCallId], references: [id], onDelete: Cascade)
  taskId            String?
  task              HarmonyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agentRunId        String?
  agentRun          AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  toolId            String
  status            String
  mode              String
  inputSnapshotJson String
  resultJson        String?
  executionPlanId   String?
  executionReceiptId String?
  executorId        String?
  sandboxId         String?
  executionPolicyId String?
  recoveryPointId   String?
  sideEffectClass   String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([toolCallId])
  @@index([idempotencyKey])
  @@index([taskId])
  @@index([agentRunId])
  @@index([status])
  @@index([mode])
  @@index([executionPlanId])
  @@index([executionReceiptId])
  @@map("tool_runs")
}

model ToolExecutor {
  id                          String   @id
  executorVersion             String
  toolId                      String
  toolCategory                String
  executionMode               String
  enabled                     Boolean
  sandboxId                   String
  policyId                    String
  maxInputSizeChars           Int
  maxOutputSizeChars          Int
  timeoutMs                   Int
  idempotencyRequired         Boolean
  sideEffectClass             String
  deterministicOutputRequired Boolean
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([toolId])
  @@index([toolCategory])
  @@index([enabled])
  @@map("tool_executors")
}

model ToolSandbox {
  id                      String   @id
  sandboxVersion          String
  mode                    String
  allowShell              Boolean
  allowGit                Boolean
  allowFileRead           Boolean
  allowFileWrite          Boolean
  allowNetwork            Boolean
  allowExternalApi        Boolean
  allowMcp                Boolean
  allowBrowser            Boolean
  allowDatabaseMigration  Boolean
  allowEnvironmentRead    Boolean
  allowQueue              Boolean
  allowWorker             Boolean
  maxRuntimeMs            Int
  maxInputSizeChars       Int
  maxOutputSizeChars      Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([mode])
  @@map("tool_sandboxes")
}

model ToolExecutionPolicy {
  id                                  String   @id
  policyVersion                       String
  status                              String
  defaultDecision                     String
  allowedToolCategoriesJson           String
  deniedToolCategoriesJson            String
  requiresKelvinForRiskJson           String
  maxRuntimeMs                        Int
  maxInputSizeChars                   Int
  maxOutputSizeChars                  Int
  requireRecoveryPointBeforeExecution Boolean
  requireAuditEvent                   Boolean
  requireObservabilityEvent           Boolean
  requireIdempotencyKey               Boolean
  requireDeterministicOutput          Boolean
  allowAutomaticFutureApproval        Boolean
  allowRetry                          Boolean
  allowReplay                         Boolean
  allowRollback                       Boolean
  allowResumeExecution                Boolean
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  @@index([status])
  @@map("tool_execution_policies")
}

model ToolExecutionPlan {
  id                            String   @id @default(cuid())
  toolRunId                     String
  toolCallId                    String
  taskId                        String?
  agentRunId                    String?
  toolId                        String
  executorId                    String
  sandboxId                     String
  policyId                      String
  status                        String
  executionMode                 String
  sideEffectClass               String
  expectedSideEffectsJson       String
  reversibility                 String
  idempotencyKey                String
  inputSnapshotJson             String
  normalizedInputHash           String
  policyVersion                 String
  executorVersion               String
  requiresKelvinConfirmation    Boolean
  confirmationArtifactId        String?
  recoveryPointId               String?
  evalRunIdsJson                String?
  regressionGateId              String?
  releaseReadinessChecklistId   String?
  sandboxProfileId              String?
  allowedWriteRoot              String?
  allowedExtensionsJson         String?
  expectedOutputPath            String?
  expiresAt                     DateTime?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([toolRunId])
  @@index([toolCallId])
  @@index([taskId])
  @@index([agentRunId])
  @@index([status])
  @@index([createdAt])
  @@map("tool_execution_plans")
}

model ToolExecutionReceipt {
  id                      String   @id @default(cuid())
  toolRunId               String
  toolCallId              String
  taskId                  String?
  agentRunId              String?
  toolId                  String
  executorId              String
  executionPlanId         String
  status                  String
  startedAt               DateTime
  completedAt             DateTime
  durationMs              Int
  idempotencyKey          String
  inputHash               String
  outputHash              String?
  policyVersion           String
  executorVersion         String
  resultSummary           String
  resultSnapshotJson      String?
  sideEffectsJson         String
  sideEffectClass         String
  reversibility           String
  simulatedReadsJson      String?
  sandboxExecutionRecordId String?
  outputPath              String?
  bytesWritten            Int?
  auditEventIdsJson       String
  observabilityEventIdsJson String
  recoveryPointId         String
  createdAt               DateTime @default(now())

  @@index([toolRunId])
  @@index([toolCallId])
  @@index([executionPlanId])
  @@index([status])
  @@index([createdAt])
  @@map("tool_execution_receipts")
}

model EvalTarget {
  id                 String   @id @default(cuid())
  idempotencyKey     String?  @unique
  correlationId      String?
  targetType         String
  targetId           String
  routeDecisionId    String?
  taskId             String?
  agentRunId         String?
  agentResultId      String?
  toolCallId         String?
  toolPermissionId   String?
  memoryEntryId      String?
  knowledgeItemId    String?
  contextPacketId    String?
  a2aMessageId       String?
  source             String
  snapshotJson       String
  snapshotVersion    String
  snapshotHash       String?
  status             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([targetType])
  @@index([targetId])
  @@index([taskId])
  @@index([agentRunId])
  @@index([toolCallId])
  @@index([status])
  @@index([createdAt])
  @@map("eval_targets")
}

model EvalRun {
  id                      String   @id @default(cuid())
  evalTargetId            String
  targetType              String
  targetId                String
  evaluatorId             String
  evaluatorMode           String
  status                  String
  trigger                 String
  checksSummaryJson       String
  qualityGateDecisionJson String?
  inputSnapshotJson       String
  outputSnapshotJson      String?
  errorJson               String?
  idempotencyKey          String?  @unique
  correlationId           String?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([evalTargetId])
  @@index([targetType])
  @@index([targetId])
  @@index([status])
  @@index([createdAt])
  @@map("eval_runs")
}

model EvalCheck {
  id             String   @id @default(cuid())
  evalRunId      String
  evalTargetId   String
  checkKey       String
  title          String
  category       String
  status         String
  severity       String
  confidence     Float
  targetPath     String?
  targetField    String?
  evidenceJson   String
  evidenceRefsJson String?
  recommendation String?
  createdAt      DateTime @default(now())

  @@index([evalRunId])
  @@index([evalTargetId])
  @@index([status])
  @@index([severity])
  @@map("eval_checks")
}

model EvalFinding {
  id                     String   @id @default(cuid())
  evalRunId              String
  evalTargetId           String
  relatedCheckIdsJson    String
  severity               String
  category               String
  title                  String
  description            String
  targetPath             String?
  targetField            String?
  evidenceJson           String
  evidenceRefsJson       String?
  recommendation         String
  status                 String
  needsHumanReview       Boolean
  confirmationArtifactId String?
  reviewedBy             String?
  reviewedAt             DateTime?
  reviewDecision         String?
  reviewReason           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([evalRunId])
  @@index([evalTargetId])
  @@index([status])
  @@index([severity])
  @@map("eval_findings")
}

model ObservabilityEvent {
  id             String   @id @default(cuid())
  schemaVersion  String
  correlationId  String
  resourceType   String
  resourceId     String
  eventType      String
  severity       String
  message        String
  source         String
  attributesJson String?
  redactionJson  String?
  createdAt      DateTime @default(now())

  @@index([correlationId])
  @@index([resourceType, resourceId])
  @@index([eventType])
  @@index([createdAt])
  @@map("observability_events")
}

model RunJournal {
  id                      String   @id @default(cuid())
  schemaVersion           String
  runType                 String
  runId                   String
  correlationId           String
  seq                     Int
  eventRefType            String
  eventRefId              String
  eventId                 String?
  phase                   String?
  stateBefore             String?
  stateAfter              String?
  inputHash               String?
  outputHash              String?
  inputSnapshotJson       String?
  outputSnapshotJson      String?
  result                  String
  failureClassificationId String?
  createdAt               DateTime @default(now())

  @@unique([runType, runId, seq])
  @@index([correlationId])
  @@index([runType, runId])
  @@index([eventRefType, eventRefId])
  @@index([createdAt])
  @@map("run_journals")
}

model RecoveryPoint {
  id                       String   @id @default(cuid())
  schemaVersion            String
  snapshotSchemaVersion    String
  correlationId            String
  resourceType             String
  resourceId               String
  resourceStatusAtSnapshot String?
  reason                   String
  snapshotJson             String?
  snapshotHash             String?
  redactionStatus          String
  redactionJson            String?
  restorableViewOnly       Boolean
  canTriggerExecution      Boolean
  createdBy                String
  createdAt                DateTime @default(now())

  @@index([correlationId])
  @@index([resourceType, resourceId])
  @@index([redactionStatus])
  @@index([createdAt])
  @@map("recovery_points")
}

model ResumeToken {
  id             String   @id @default(cuid())
  schemaVersion  String
  tokenHash      String   @unique
  correlationId  String
  resourceType   String
  resourceId     String
  mode           String
  viewContextJson String
  maxUses        Int?
  useCount       Int
  expiresAt      DateTime?
  revokedAt      DateTime?
  revokedReason  String?
  createdBy      String
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([correlationId])
  @@index([resourceType, resourceId])
  @@index([mode])
  @@index([createdAt])
  @@map("resume_tokens")
}

model FailureClassification {
  id              String   @id @default(cuid())
  schemaVersion   String
  correlationId   String
  resourceType    String
  resourceId      String
  category        String
  severity        String
  retryable       Boolean
  retryableReason String
  message         String
  evidenceJson    String?
  createdBy       String
  createdAt       DateTime @default(now())

  @@index([correlationId])
  @@index([resourceType, resourceId])
  @@index([category])
  @@index([severity])
  @@index([createdAt])
  @@map("failure_classifications")
}

model CollaborationSession {
  id                               String   @id @default(cuid())
  idempotencyKey                   String?  @unique
  correlationId                    String
  taskId                           String?
  sourceA2AMessageId               String?
  sourceAgentRunId                 String?
  sourceEvalRunId                  String?
  teamId                           String?
  status                           String
  objective                        String
  summary                          String?
  riskLevel                        String
  requiresHumanConfirmation        Boolean
  participantsJson                 String
  planJson                         String
  confirmationArtifactId           String?
  supersedesCollaborationSessionId String?
  supersededByCollaborationSessionId String?
  createdBy                        String
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@index([correlationId])
  @@index([taskId])
  @@index([sourceA2AMessageId])
  @@index([sourceAgentRunId])
  @@index([status])
  @@index([createdAt])
  @@map("collaboration_sessions")
}

model A2AThread {
  id                     String   @id @default(cuid())
  idempotencyKey         String?  @unique
  correlationId          String
  collaborationSessionId String
  taskId                 String?
  status                 String
  topic                  String
  purpose                String
  participantAgentIdsJson String
  latestTurnSeq          Int
  createdBy              String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([correlationId])
  @@index([collaborationSessionId])
  @@index([taskId])

# 数据库
DATABASE_URL="file:./dev.db"

# LLM Provider
# mock - 使用 Mock Provider（本地开发，无需 API Key）
#        mock 模式下 LLM Router 和 Agent Runtime 返回模拟结构化数据
# claude - 使用 Claude API（需要 ANTHROPIC_API_KEY）
#          启用 LLM 驱动的 CEO Router（Haiku）和 Agent Runtime（Sonnet）
LLM_PROVIDER="mock"

# Claude API Key（LLM_PROVIDER=claude 时必填）
# 从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=""

# System Prompt（可选，不设置时使用默认值）
SYSTEM_PROMPT=""

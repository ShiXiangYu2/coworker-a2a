# 数据库
DATABASE_URL="file:./dev.db"

# LLM Provider
# mock - 使用 Mock Provider（本地开发，无需 API Key）
#        mock 模式下 LLM Router 和 Agent Runtime 返回模拟结构化数据
# claude - 使用 Claude API（需要 ANTHROPIC_API_KEY）
#          启用 LLM 驱动的 CEO Router（Haiku）和 Agent Runtime（Sonnet）
# deepseek - 使用 DeepSeek API（需要 DEEPSEEK_API_KEY）
#            支持 OpenAI 和 Anthropic 两种格式
# stepfun - 使用 StepFun API（需要 STEPFUN_API_KEY）
LLM_PROVIDER="mock"

# Claude API Key（LLM_PROVIDER=claude 时必填）
# 从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=""

# DeepSeek API Key（LLM_PROVIDER=deepseek 时必填）
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=""

# DeepSeek API 基础 URL（可选，默认 https://api.deepseek.com）
# 支持 Anthropic 格式：https://api.deepseek.com/anthropic
DEEPSEEK_BASE_URL=""

# DeepSeek 模型名称（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=""

# StepFun API Key（LLM_PROVIDER=stepfun 时必填）
# 从 https://platform.stepfun.com/ 获取
STEPFUN_API_KEY=""

# StepFun API 基础 URL（可选，默认 https://api.stepfun.com）
STEPFUN_BASE_URL=""

# StepFun 模型名称（可选，默认 step-3.7-flash）
STEPFUN_MODEL=""

# System Prompt（可选，不设置时使用默认值）
SYSTEM_PROMPT=""

# 本地认证 Token（可选，用于 API 认证）
LOCAL_AUTH_TOKEN=""

# ─── 认证 ───────────────────────────────────────────────────────────
# JWT 密钥（生产环境必须修改！）
JWT_SECRET="change-this-to-a-random-secret-key"

# ─── GitHub（可选，用于部署流水线）──────────────────────────────────
# GITHUB_TOKEN="ghp_your-github-token"
# GITHUB_REPO_OWNER="your-org"
# GITHUB_REPO_NAME="your-repo"

# ─── Obsidian（可选，用于知识库集成）────────────────────────────────
# OBSIDIAN_API_URL="http://localhost:27123"
# OBSIDIAN_API_KEY="your-obsidian-api-key"
# OBSIDIAN_VAULT="your-vault-name"

# ─── 成本预算 ───────────────────────────────────────────────────────
COST_BUDGET_DAILY=10
COST_BUDGET_WEEKLY=50
COST_BUDGET_MONTHLY=200

# ─── Langfuse 监控（可选）──────────────────────────────────────────
# 从 https://langfuse.com/ 获取
# LANGFUSE_PUBLIC_KEY="pk-lf-your-public-key"
# LANGFUSE_SECRET_KEY="sk-lf-your-secret-key"
# LANGFUSE_BASE_URL="https://cloud.langfuse.com"
